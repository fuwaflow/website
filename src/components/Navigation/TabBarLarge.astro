---
import { pages } from "./nav.js";
import { icons } from "./icons.js";
---

<style>
  #tab-bar-large {
    padding: 0.25rem;
    width: fit-content;
    backdrop-filter: blur(2px);
    border-radius: 999px;
    background-color: oklch(from var(--accent-color) 0.98 0.03 h / 90%);
    box-shadow:
      0 0.3rem 0.3rem rgba(0, 0, 0, 0.1),
      0 0 1rem rgba(0, 0, 0, 0.05),
      inset 0 1px 1px rgba(255, 255, 255, 0.5),
      inset 0 0 0.27rem rgba(255, 255, 255, 0.5);

    @media (prefers-color-scheme: dark) {
      background-color: oklch(from var(--accent-color) 0.24 0.017 h / 90%);
      box-shadow:
        0 0.3rem 0.3rem rgba(0, 0, 0, 0.1),
        0 0 1rem rgba(0, 0, 0, 0.05),
        inset 0 1px 1px oklch(1 0 0 / 0.1),
        inset 0 0 0.27rem rgba(255, 255, 255, 0.1);
    }

    .nav {
      display: flex;
      list-style: none;
      margin: 0;
      padding: 0;
      gap: 0.25rem;

      .nav-item {
        border-radius: 999px;

        a {
          padding: 0.25rem 1.25rem;
          border-radius: inherit;
          display: flex;
          align-items: center;
          gap: 0.3rem;
          font-weight: 600;
          line-height: 150%;
          text-decoration: none;
          color: var(--text-color);
        }

        a:hover {
          background-color: oklch(0 0 0 / 0.07);
          @media (prefers-color-scheme: dark) {
            background-color: oklch(1 0 0 / 0.06);
          }
        }

        a.active {
          font-weight: 750;
          background-color: oklch(0 0 0 / 0.05);
          color: var(--accent-color);
          @media (prefers-color-scheme: dark) {
            background-color: oklch(1 0 0 / 0.04);
          }
        }

        svg {
          width: 1rem;
          height: 1rem;
          flex-shrink: 0;
        }
      }
    }
  }
</style>

<script>
  const links = document.querySelectorAll(".nav-item a");
  const current = location.pathname;

  links.forEach((link) => {
    const href = new URL(link.href).pathname;

    if (href === "/" && current === "/") {
      link.classList.add("active");
      return;
    }

    if (href !== "/" && current.startsWith(href)) {
      link.classList.add("active");
    }
  });
</script>

<div id="tab-bar-large">
  <ul class="nav">
    {
      pages.map((page) => (
        <li class="nav-item">
          <a href={page.url}>
            {icons[page.url] && <Fragment set:html={icons[page.url]} />}
            {page.title.toLowerCase()}
          </a>
        </li>
      ))
    }
  </ul>
</div>
