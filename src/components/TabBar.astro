---
const navItems = [
  { href: "/", text: "home" },
  { href: "/blog", text: "blog" },
  { href: "/portfolio", text: "portfolio" },
];
const pathname = new URL(Astro.request.url).pathname;
---

<nav class="tab-bar">
  {
    navItems.map((item) => (
      <a
        href={item.href}
        class="tab-item"
        aria-current={pathname === item.href ? "page" : undefined}
      >
        {item.text}
      </a>
    ))
  }
</nav>
