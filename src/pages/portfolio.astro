---
import Layout from "../layouts/layout.astro";

const pageTitle = "fuwaflow's portfolio";

const allPosts = Object.values(import.meta.glob("./blog/*.md", { eager: true }))
  .filter((post: any) =>
    post.frontmatter.tags
      ?.map((t: string) => t.toLowerCase())
      .includes("portfolio"),
  )
  .sort((a: any, b: any) => {
    const dateA = new Date(a.frontmatter?.date ?? 0).getTime();
    const dateB = new Date(b.frontmatter?.date ?? 0).getTime();
    return dateB - dateA;
  });
---

<Layout title={pageTitle}>
  <main>
    <section>
      <h1 style="color: var(--accent);" class="h0">{pageTitle}</h1>
      <p>
        welcome to my portfolio! here are the projects and works i've been
        focusing on.
      </p>
      <hr />
    </section>

    <section>
      <h2>featured projects</h2>
      <div class="card-grid">
        {
          allPosts.map((post: any) => (
            <a
              href={post.url}
              class="card"
              style="text-decoration: none; color: inherit; display: block;"
            >
              {post.frontmatter.tags && (
                <p style="font-size: 0.8rem; opacity: 0.8;">
                  {post.frontmatter.tags.map((tag) => (
                    <span>{tag}, </span>
                  ))}
                </p>
              )}

              <h3>{post.frontmatter.title}</h3>

              <p style="font-size: 0.9rem; opacity: 0.7;">
                {new Date(post.frontmatter.date).toLocaleDateString("en-GB", {
                  year: "numeric",
                  month: "long",
                  day: "numeric",
                })}
              </p>
            </a>
          ))
        }
      </div>
      <hr />
    </section>
  </main>
</Layout>
