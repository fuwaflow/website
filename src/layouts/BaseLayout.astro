---
const { pageTitle } = Astro.props;
import TabBar from "../components/TabBar.astro";
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <title>{pageTitle}</title>
  </head>
  <body>
    <main>
      <TabBar />
      <slot />
    </main>
  </body>
</html>
